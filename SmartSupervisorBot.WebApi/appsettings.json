{
  "ConnectionStrings": {
    "Redis": "localhost,abortConnect=false"
  },
  "BotConfiguration": {
    "BotSettings": {
      "BotToken": "YOUR_TOKEN_HERE",
      "OpenAiToken": "YOUR_API_KEY_HERE",
      "BaseRequestUrl": "https://api.telegram.org/bot"
    },
    "OpenAiModel": "gpt-5.4-nano", // "gpt-3.5-turbo-instruct", "gpt-4o-mini", "gpt-5.4-nano"
    "TranslateTheTextTo": "Deutsch",
    "UnifiedTextSettings": {
      "MaxTokens": 60,
      "Temperature": 0.1,
      "Prompt": "Text: {input}\nWenn nicht auf {language}, komplett übersetzen. Sonst korrigieren. Nur Ergebnis."
    },
    "AllowedUpdatesSettings": {
      "AllowedUpdates": [
        "Message",
        "InlineQuery",
        "ChosenInlineResult",
        "CallbackQuery",
        "EditedMessage",
        "ChannelPost",
        "EditedChannelPost",
        "ShippingQuery",
        "PreCheckoutQuery",
        "Poll",
        "PollAnswer",
        "MyChatMember",
        "ChatMember",
        "ChatJoinRequest"
      ]
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/app-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
